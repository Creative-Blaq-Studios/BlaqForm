{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "BlaqForm Example App",
      "type": "dart",
      "request": "launch",
      "program": "blaq_form/example/lib/main.dart",
      "args": ["-v"]
    },
    {
      "name": "BlaqForm Example (Chrome)",
      "type": "dart",
      "request": "launch",
      "program": "blaq_form/example/lib/main.dart",
      "args": ["-d", "chrome"]
    },
    {
      "name": "BlaqForm Example (macOS)",
      "type": "dart",
      "request": "launch",
      "program": "blaq_form/example/lib/main.dart",
      "args": ["-d", "macos","-v"]
    },
    {
      "name": "BlaqForm Tests",
      "type": "dart",
      "request": "launch",
      "program": "blaq_form/test/",
      "cwd": "${workspaceFolder}/blaq_form"
    }
  ]
}
